/**index.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #FFF8E7 0%, #FFE4B5 50%, #FFD700 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 60rpx 30rpx;
  box-sizing: border-box;
}

/* 顶部分数区域 */
.score-header {
  display: flex;
  justify-content: space-around;
  width: 100%;
  margin-bottom: 80rpx;
}

.score-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.85);
  border-radius: 30rpx;
  padding: 30rpx 50rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.score-label {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 10rpx;
}

.score-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #FF6B00;
}

.score-value.best {
  color: #FFD700;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

/* 金币区域 */
.coin-area {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.coin-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 300rpx;
  height: 300rpx;
  background: linear-gradient(145deg, #FFE57F 0%, #FFD700 50%, #FFA000 100%);
  border-radius: 50%;
  box-shadow: 
    0 20rpx 60rpx rgba(255, 165, 0, 0.4),
    inset 0 -10rpx 30rpx rgba(0, 0, 0, 0.1),
    inset 0 10rpx 30rpx rgba(255, 255, 255, 0.5);
  cursor: pointer;
  transition: transform 0.1s ease;
}

.coin-wrapper:active {
  transform: scale(0.95);
}

.coin-pop {
  animation: coinPop 0.3s ease-out;
}

@keyframes coinPop {
  0% { transform: scale(1); }
  50% { transform: scale(1.3); }
  100% { transform: scale(1); }
}

.coin-emoji {
  font-size: 160rpx;
  line-height: 1;
}

/* 飘字特效 */
.float-container {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  overflow: hidden;
}

.float-text {
  position: absolute;
  font-size: 50rpx;
  font-weight: bold;
  color: #FF6B00;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.2);
  opacity: 0;
  transform: translateY(0);
  transition: all 0.8s ease-out;
}

.float-show {
  opacity: 1;
  transform: translateY(-100rpx);
}

/* 底部提示 */
.tip-text {
  font-size: 28rpx;
  color: #A0522D;
  margin-top: 80rpx;
  opacity: 0.8;
}